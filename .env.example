# Copy to .env for local dev. For GitHub Pages, add these as repository Secrets (see README).

VITE_LOCAL_DEV=false

# Supabase (shared database — safe to use anon/publishable key in the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# AI research (embedded at build time for GitHub Pages; also used in local dev)
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=

# Server-only — Edge Function deploy / local function testing (never commit real values)
SUPABASE_SERVICE_ROLE_KEY=
