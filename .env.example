# Copy to .env for local dev. For GitHub Pages, add these as repository Secrets (see README).

VITE_LOCAL_DEV=false

# Supabase (shared database — safe to use anon/publishable key in the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Server-only (local dev / hosted server — NOT used on static GitHub Pages)
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
